# -----------------------------------------------------------------------------
# serviceHub Environment Variables
#
# This file serves as a template for the required environment variables.
# Copy this file to .env and fill in the values for your specific environment.
# The .env file is ignored by Git to keep your secrets safe.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# --> System & General Settings
# Your local timezone (e.g., "Australia/Sydney", "America/New_York")
TIME_ZONE="Australia/Sydney"
# Base path on the host machine where application data will be stored
APPS_DATA="~/Documents/containerd"

# --> Domain & Network Settings
# Your primary domain name
DOMAIN_NAME="example.local"
TRUSTED_IP="127.0.0.0/8, 10.0.0.0/8, 172.0.0.0/8, 192.168.0.0/16, fe80::/10, ::1/128"

# -----------------------------------------------------------------------------
# --> Email Service Variables
SMTP_HOST="smtp.${DOMAIN_NAME}"
SMTP_PORT="465"
SMTP_USER="mail@${DOMAIN_NAME}"
SMTP_PASS="<YOUR_SMTP_PASSWORD>"
SMTP_FROM="no-reply@${DOMAIN_NAME}"

# -----------------------------------------------------------------------------
# --> Service Variables

# Traefik
TRAFIK_DOMAIN="traefik.${DOMAIN_NAME}"
ACME_EMAIL="youremail@${DOMAIN_NAME}"
# to create a user:password pair, the following command can be used
# echo $(htpasswd -nb user "password") | sed -e s/\\$/\\$\\$/g
TRAFIK_BAAUTH="user1$$password,user2$$password"
# TLS certificate resolver: set to "letsencrypt" for LetsEncrypt, leave empty for self-signed certificate
CERTRESOLVER=letsencrypt

# Authentik
AUTHK_TAG="2026.2"
AUTHK_PASSWD="<YOUR_STRONG_AUTHENTIK_PASSWORD>"
AUTHK_SECRET="<YOUR_STRONG_AUTHENTIK_SECRETKEY>"
AUTHK_DBNAME="authentik"
AUTHK_DOMAIN="accounts.${DOMAIN_NAME}"

# Wordpress
WP_DBNAME="wordpress"
WP_DOMAIN="www.${DOMAIN_NAME}"

# Gitea: Git with a cup of tea
GIT_DBNAME="gitea"
GIT_DOMAIN="codex.${DOMAIN_NAME}"
# Runner token from Gitea -> Organization/Repository -> Settings -> Actions -> Runners
GIT_RUNNER_TOKEN="<your-runner-token>"

# Hermes Agent - Nous Research's AI agent platform
HERMES_DOMAIN="workflow.${DOMAIN_NAME}"

# Open WebUI - Web interface for LLMs
OWEBUI_DOMAIN="chats.${DOMAIN_NAME}"

# LLM Inference Services (llama.cpp — CPU-only, 32 GB RAM optimised)
# Models are auto-downloaded via -hf flag and cached in ${APPS_DATA}/agentmodels
# Format: <hf-repo>:<quant>  e.g. ggml-org/gemma-4-E2B-it-GGUF:Q8_0
# Fast chat (Gemma 4 2B edge Q8_0 recommended)
LLM_CHAT_MODEL="unsloth/gemma-4-E2B-it-GGUF:Q4_K_M"
LLM_CHAT_ARGMS="--ctx-size 65536 --threads 6 --threads-batch 6 --flash-attn on --cache-type-k q4_0 --cache-type-v q4_0 --temp 0.0 --parallel 1 --no-mmap --mlock --cont-batching"
LLM_CHAT_PORT="12321"

# Deep reasoning (Gemma 4 26B Q4_K_M recommended)
LLM_LOGC_MODEL="unsloth/Qwen3.6-27B-GGUF:Q4_K_M"
LLM_LOGC_ARGMS="--ctx-size 65536 --threads 8 --threads-batch 12 --flash-attn on --cache-type-k q4_0 --cache-type-v q4_0 --temp 0.0 --parallel 1 --no-mmap --mlock --cont-batching"
LLM_LOGC_PORT="12322"

# Vector embeddings (Qwen3-Embedding 0.6B Q8_0 recommended)
LLM_EMBD_MODEL="Qwen/Qwen3-Embedding-0.6B-GGUF:Q8_0"
LLM_EMBD_ARGMS="--ctx-size 4096 --threads 3 --threads-batch 4 --flash-attn on --cache-type-k q8_0 --cache-type-v q8_0 --parallel 4 --embedding --pooling last --mlock"
LLM_EMBD_PORT="12323"

# -----------------------------------------------------------------------------
# --> security observability Stack Variables (VictoriaMetrics + VictoriaLogs + Grafana)

# Grafana - Observability dashboards (public-facing, needs domain)
GF_DOMAIN="stats.${DOMAIN_NAME}"
GF_ADMIN_USER="admin"
GF_ADMIN_PASSWORD="<YOUR_STRONG_SQLDB_PASSWORD>"

# -----------------------------------------------------------------------------
# --> Database Service Variables

# DB common variables
# Credentials for the main database service.
# SQLDB_USER and SQLDB_PASS are used by the MariaDB / PostgreSQL image on first run to create a superuser.
SQLDB_USER="dbservice"
SQLDB_PASS="<YOUR_STRONG_SQLDB_PASSWORD>"

# MariaDB/MySQL
MySQL_HOST="inframariadb"
MySQL_PORT=3306
# Create multiple databases, using "db1,db2"
MARIADB_DB_LIST="${WP_DBNAME}"

# PostgreSQL
PGRSQL_HOST="infrapgsqldb"
PGRSQL_PORT=5432
# Create multiple databases, using "db1,db2"
PGRSQL_DBLIST="${AUTHK_DBNAME},${GIT_DBNAME}"
