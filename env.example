# -----------------------------------------------------------------------------
# serviceHub Environment Variables
#
# This file serves as a template for the required environment variables.
# Copy this file to .env and fill in the values for your specific environment.
# The .env file is ignored by Git to keep your secrets safe.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# --> System & General Settings
# Your local timezone (e.g., "Australia/Sydney", "America/New_York")
TIME_ZONE="Australia/Sydney"
# Base path on the host machine where application data will be stored
APPS_DATA="~/Documents/containerd"

# --> Domain & Network Settings
# Your primary domain name
DOMAIN_NAME="example.local"
TRUSTED_IP="127.0.0.0/8, 10.0.0.0/8, 172.0.0.0/8, 192.168.0.0/16, fe80::/10, ::1/128"

# -----------------------------------------------------------------------------
# --> Email Service Variables
SMTP_HOST="smtp.${DOMAIN_NAME}"
SMTP_PORT="465"
SMTP_USER="mail@${DOMAIN_NAME}"
SMTP_PASS="<YOUR_STRONG_SQLDB_PASSWORD>"
SMTP_FROM="no-reply@${DOMAIN_NAME}"

# -----------------------------------------------------------------------------
# --> Service Variables

# Traefik
TRAFIK_DOMAIN="traefik.${DOMAIN_NAME}"
ACME_EMAIL="youremail@${DOMAIN_NAME}"
# to create a user:password pair, the following command can be used
# echo $(htpasswd -nb user "password") | sed -e s/\\$/\\$\\$/g
TRAFIK_BAAUTH="user1$$password,user2$$password"

# Authentik
AUTHK_TAG="2025.12"
AUTHK_PASSWD="<YOUR_STRONG_AUTHENTIK_PASSWORD>"
AUTHK_SECRET="<YOUR_STRONG_AUTHENTIK_SECRETKEY>"
AUTHK_DBNAME="authentik"
AUTHK_DOMAIN="accounts.${DOMAIN_NAME}"

# Wordpress
WP_DBNAME="wordpress"
WP_DOMAIN="www.${DOMAIN_NAME}"

# Gitea: Git with a cup of tea
GIT_DBNAME="gitea"
GIT_DOMAIN="codex.${DOMAIN_NAME}"

# OpenMAIC: Open Multi-Agent Interactive Classroom
OMAIC_DOMAIN="learn.${DOMAIN_NAME}"
# OpenAI API key for LLM calls
OMAIC_OPENAI_API_KEY=
# OpenAI API base URL (e.g., https://api.openai.com/v1)
OMAIC_OPENAI_BASE_URL=
# Comma-separated list of model names (e.g., gpt-4o,gpt-4o-mini)
OMAIC_OPENAI_MODELS=

# -----------------------------------------------------------------------------
# --> Database Service Variables

# DB common variables
# Credentials for the main database service.
# SQLDB_USER and SQLDB_PASS are used by the MariaDB / PostgreSQL image on first run to create a superuser.
SQLDB_USER="dbservice"
SQLDB_PASS="<YOUR_STRONG_SQLDB_PASSWORD>"

# MariaDB/MySQL
MySQL_HOST="mariadb"
MySQL_PORT=3306
# Create multiple databases, using "db1,db2"
MARIADB_DB_LIST="${WP_DBNAME},${GIT_DBNAME}"

# PostgreSQL
PGRSQL_HOST="pgsqldb"
PGRSQL_PORT=5432
# Create multiple databases, using "db1,db2"
PGRSQL_DBLIST="${AUTHK_DBNAME}"