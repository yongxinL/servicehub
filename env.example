# -----------------------------------------------------------------------------
# serviceHub Environment Variables
#
# This file serves as a template for the required environment variables.
# Copy this file to .env and fill in the values for your specific environment.
# The .env file is ignored by Git to keep your secrets safe.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# --> System & General Settings
# Your local timezone (e.g., "Australia/Sydney", "America/New_York")
TIME_ZONE="Australia/Sydney"
# Base path on the host machine where application data will be stored
APPS_DATA="~/Documents/containerd"

# --> Domain & Network Settings
# Your primary domain name
DOMAIN_NAME="example.local"
TRUSTED_IP="127.0.0.0/8, 10.0.0.0/8, 172.0.0.0/8, 192.168.0.0/16, fe80::/10, ::1/128"

# -----------------------------------------------------------------------------
# --> Email Service Variables
SMTP_HOST="smtp.${DOMAIN_NAME}"
SMTP_PORT="465"
SMTP_USER="mail@${DOMAIN_NAME}"
SMTP_PASS="<YOUR_SMTP_PASSWORD>"
SMTP_FROM="no-reply@${DOMAIN_NAME}"

# -----------------------------------------------------------------------------
# --> Service Variables

# Traefik
TRAFIK_DOMAIN="traefik.${DOMAIN_NAME}"
ACME_EMAIL="youremail@${DOMAIN_NAME}"
# HTTP Basic Auth for Traefik dashboard (htpasswd format: user:$apr1$...)
# Generate with: echo $(htpasswd -nb user "password") | sed -e 's/\\$/\$\$/g'
TRAFIK_BAAUTH=""
# TLS certificate resolver: "letsencrypt" for Let's Encrypt, empty for self-signed
CERTRESOLVER=letsencrypt

# Authentik
AUTHK_TAG="2026.2"
AUTHK_PASSWD="<YOUR_STRONG_AUTHENTIK_PASSWORD>"
AUTHK_SECRET="<YOUR_STRONG_AUTHENTIK_SECRETKEY>"
AUTHK_DBNAME="authentik"
AUTHK_DOMAIN="accounts.${DOMAIN_NAME}"

# Wordpress
WEBHOM_DBNAME="wordpress"
WEBHOM_DOMAIN="www.${DOMAIN_NAME}"

# Gitea: Git with a cup of tea
REPBUK_DBNAME="gitea"
REPBUK_DOMAIN="codex.${DOMAIN_NAME}"
# Runner token from Gitea -> Organization/Repository -> Settings -> Actions -> Runners
REPBUK_RUNTOKEN="<your-runner-token>"

# LLM Inference Services (llama.cpp — CPU-only, 32 GB RAM optimised)
# Model auto-downloaded via -hf flag and cached in ${APPS_DATA}/agentmodels
# Format: <hf-repo>:<quant>  e.g. "unsloth/gemma-4-E4B-it-GGUF:Q4_K_M"
LLAMA_CHTMDL="unsloth/gemma-4-E4B-it-GGUF:Q4_K_M"
# llama.cpp server flags (see https://github.com/ggerganov/llama.cpp/blob/master/examples/server/README.md)
# --ctx-size: context window size (65536 = 64K tokens)
# --threads / --threads-batch: CPU thread counts for inference and batch processing
# --flash-attn: enable flash attention (on/off)
# --cache-type-k / --cache-type-v: KV cache quantization types
# --temp: sampling temperature (0.0 = deterministic)
# --parallel: max concurrent inference requests
# --no-mmap --mlock: disable memory mapping, use RAM instead (safer for swapped environments)
# --cont-batching: enable continuous batching for better throughput
LLAMA_CHTARG="--ctx-size 65536 --threads 10 --threads-batch 12 --flash-attn on --cache-type-k q4_0 --cache-type-v q4_0 --temp 0.0 --parallel 4 --no-mmap --mlock --cont-batching --ubatch-size 1024"

# LiteLLM Proxy — unified API gateway routing requests across local and cloud LLM providers
# Master API key — used as Bearer token by Hermes and other services to authenticate with the proxy (format: sk-...)
LITEM_APIKEY="<YOUR_LITELLM_MASTER_API_KEY>"
# Base URL Hermes Agent (and any other in-stack client) uses to reach the LiteLLM proxy.
# Default points at the in-network agsvclitellm service; override to point at an external
# LiteLLM deployment (e.g. https://litellm.example.com/v1) if you are not running it locally.
LITEM_APIBASE="http://agsvclitellm:12380/v1"
# Admin UI credentials for the LiteLLM web dashboard (http://<host>:12380/ui)
LITEM_ADMUSR="admin"
LITEM_ADMPWD="<YOUR_STRONG_SQLDB_PASSWORD>"
LITEM_DBNAME="litellm"

# Hephaestus — local llama.cpp edge inference (or remote edge service)
# API key is "none" for local llama.cpp, use actual key if using a remote edge service
LITEM_HPH_APIURL="http://agsvcchatllm:12386/v1"
LITEM_HPH_APIKEY="none"
# Health check for auto-failover routing (used by smartrouter.py)
LITEM_HPH_HLTURL="http://agsvcchatllm:12386/health"

# Prometheus — MiniMax cloud LLM provider (Anthropic-compatible API, cloud fallback)
LITEM_PRM_APIBASE="https://api.minimax.io/anthropic"
LITEM_PRM_APIKEY="<your-minimax-api-key>"

# FastCRW (Firecrawl-compatible) — self-hosted web scraping + search service.
# Base URL Hermes Agent uses for web.base_url and the FastCRW client.
# Default points at the in-network agsvcfastcrw service; override to point at
# an external Firecrawl-compatible deployment if you are not running locally.
FCRW_APIURL="http://agsvcfastcrw:12360"

# Open WebUI - Web interface for LLMs
OWEBUI_DOMAIN="chats.${DOMAIN_NAME}"

# -----------------------------------------------------------------------------
# --> security observability Stack Variables (VictoriaMetrics + VictoriaLogs + Grafana)

# Grafana - Observability dashboards (public-facing, needs domain)
SECOB_DOMAIN="stats.${DOMAIN_NAME}"
SECOB_ADMUSR="admin"
SECOB_ADMPWD="<YOUR_STRONG_GRAFANA_PASSWORD>"

# -----------------------------------------------------------------------------
# --> Database Service Variables

# DB common variables
# Root credentials used by MariaDB and PostgreSQL containers on first startup to create the superuser.
SQLDB_USER="dbservice"
SQLDB_PASS="<YOUR_STRONG_SQLDB_PASSWORD>"

# MariaDB/MySQL
MySQL_HOST="inframariadb"
MySQL_PORT=3306
# Comma-separated list of databases to create: "db1,db2"
MARIADB_DB_LIST="${WEBHOM_DBNAME}"

# PostgreSQL
PGRSQL_HOST="infrapgsqldb"
PGRSQL_PORT=5432
# Comma-separated list of databases to create: "db1,db2"
PGRSQL_DBLIST="${AUTHK_DBNAME},${REPBUK_DBNAME},${LITEM_DBNAME}"
