# git-crypt: files matching these patterns are transparently encrypted at rest
# in the repository. Run `git-crypt unlock <key-file>` to decrypt locally.
shared/letsencrypt/selfsign/*.pem filter=git-crypt diff=git-crypt
shared/letsencrypt/selfsign/*.key filter=git-crypt diff=git-crypt
shared/letsencrypt/selfsign/*.crt filter=git-crypt diff=git-crypt