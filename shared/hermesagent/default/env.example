# =============================================================================
# Hermes Agent — default profile .env
# Seeded into /opt/data/.env (or /opt/data/profiles/<name>/.env) on first run
# if the file does not already exist.
#
# Fill in real values before or after first container start.
# The container will start but the gateway will not connect to Discord until
# DISCORD_BOT_TOKEN and DISCORD_ALLOWED_USERS are set. Edit on the host at:
#   /opt/data/hermesagent/.env               (default profile)
#   /opt/data/hermesagent/profiles/<name>/.env  (named profile)
# =============================================================================

# LiteLLM proxy — base URL and master key.
# Both placeholders are substituted on first container start by start-gateways.sh
# from LITELLM_API_BASE and LITELLM_API_KEY env vars (sourced in turn from
# LITEM_APIBASE and LITEM_APIKEY in the root servicehub .env).
LITELLM_API_BASE=<your-litellm-api-base>
LITELLM_API_KEY=<your-litellm-master-key>

# FastCRW (Firecrawl-compatible) self-hosted endpoint and auth key.
# Both placeholders are substituted on first container start by start-gateways.sh
# from FIRECRAWL_API_URL and FIRECRAWL_API_KEY env vars (sourced in turn from
# FCRW_APIURL and LITEM_APIKEY in the root servicehub .env).
# FIRECRAWL_API_KEY must match [auth] api_keys in shared/fastcrw/config.docker.toml.
FIRECRAWL_API_URL=<your-firecrawl-api-url>
FIRECRAWL_API_KEY=<your-firecrawl-api-key>

# Discord — create a bot at discord.com/developers/applications (one per profile)
# DISCORD_BOT_TOKEN=<your-discord-bot-token>
# DISCORD_ALLOWED_USERS=<discord-user-id>   # comma-separated; denies all if unset

# WhatsApp — use a dedicated phone number per profile (not a personal account)
# WHATSAPP_ENABLED=true
# WHATSAPP_MODE=bot                          # "bot" (dedicated number) or "self-chat"
# WHATSAPP_ALLOWED_USERS=<number-with-country-code-no-plus>  # e.g. 61412123456

# Optional: additional LLM provider keys if bypassing LiteLLM for some calls
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
