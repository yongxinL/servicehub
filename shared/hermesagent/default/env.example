# =============================================================================
# Hermes Agent — default profile .env
# Seeded into /opt/data/.env (or /opt/data/profiles/<name>/.env) on first run
# if the file does not already exist.
#
# Fill in real values before or after first container start.
# The container will start but the gateway will not connect to Discord until
# DISCORD_TOKEN is set. Edit on the host at:
#   ${APPS_DATA}/hermesagent/.env               (default profile)
#   ${APPS_DATA}/hermesagent/profiles/<name>/.env  (named profile)
# =============================================================================

# LiteLLM proxy master key (must match LITELLM_KEY in servicehub .env)
LITELLM_KEY=<your-litellm-master-key>

# Discord bot token for this profile (one bot token per profile)
DISCORD_TOKEN=<your-discord-bot-token>

# Firecrawl self-hosted endpoint and auth key
FIRECRAWL_API_URL=http://agsvcfircrl:3002
FIRECRAWL_API_KEY=<your-firecrawl-bull-auth-key>

# Optional: additional LLM provider keys if bypassing LiteLLM for some calls
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
